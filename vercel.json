{
  "version": 2,
  "rewrites": [
    { "source": "/sw.js", "destination": "/api/sw.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json; charset=utf-8" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/push-reminders", "schedule": "0 8 * * *" }
  ]
}
