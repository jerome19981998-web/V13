{
  "version": 2,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*.js" }
  ],
  "routes": [
    {
      "src": "/sw\\.js",
      "dest": "/sw.js",
      "headers": { "Cache-Control": "no-cache, no-store, must-revalidate" }
    },
    {
      "src": "/manifest\\.json",
      "dest": "/manifest.json",
      "headers": { "Content-Type": "application/manifest+json; charset=utf-8" }
    },
    {
      "src": "/icons/(.+)",
      "dest": "/icons/$1"
    },
    {
      "src": "/favicon\\.ico",
      "dest": "/favicon.ico"
    },
    {
      "src": "/favicon\\.svg",
      "dest": "/favicon.svg"
    },
    {
      "src": "/api/(.+)",
      "dest": "/api/$1.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "crons": [
    { "path": "/api/push-reminders", "schedule": "0 8 * * *" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
