{
  "version": 2,
  "rewrites": [
    { "source": "/sw.js", "destination": "/api/sw.js" },
    { "source": "/api/:path*", "destination": "/api/:path*.js" },
    { "source": "/((?!api|icons|manifest.json|favicon.ico|favicon.svg).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/manifest.json",
      "headers": [{ "key": "Content-Type", "value": "application/manifest+json" }]
    },
    {
      "source": "/(.*)",
      "headers": [{ "key": "X-Content-Type-Options", "value": "nosniff" }]
    }
  ],
  "crons": [
    { "path": "/api/push-reminders", "schedule": "0 8 * * *" }
  ]
}
